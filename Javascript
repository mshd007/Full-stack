<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Grade Calculator</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background-color: #f2f2f2;
        }

        .calculator-box{
            max-width: 600px;
            margin: 50px auto;
            background-color: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
        }

        h2{
            text-align: center;
            margin-bottom: 20px;
        }

        #result{
            margin-top: 20px;
            font-size: 18px;
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="container">

    <div class="calculator-box">

        <h2>Student Grade Calculator</h2>

        <label class="form-label">Math Marks</label>
        <input type="number" id="math" class="form-control mb-3" placeholder="Enter marks">

        <label class="form-label">Science Marks</label>
        <input type="number" id="science" class="form-control mb-3" placeholder="Enter marks">

        <label class="form-label">English Marks</label>
        <input type="number" id="english" class="form-control mb-3" placeholder="Enter marks">

        <label class="form-label">Computer Marks</label>
        <input type="number" id="computer" class="form-control mb-3" placeholder="Enter marks">

        <label class="form-label">Social Studies Marks</label>
        <input type="number" id="social" class="form-control mb-3" placeholder="Enter marks">

        <label class="form-label">Nepali Marks</label>
        <input type="number" id="nepali" class="form-control mb-3" placeholder="Enter marks">

        <button class="btn btn-primary w-100" onclick="calculateGrade()">
            Calculate Result
        </button>

        <div id="result"></div>

    </div>

</div>

<script>

function calculateGrade(){

    let math = Number(document.getElementById("math").value);
    let science = Number(document.getElementById("science").value);
    let english = Number(document.getElementById("english").value);
    let computer = Number(document.getElementById("computer").value);
    let social = Number(document.getElementById("social").value);
    let nepali = Number(document.getElementById("nepali").value);

    if(
        math === 0 && science === 0 && english === 0 &&
        computer === 0 && social === 0 && nepali === 0
    ){
        alert("Please enter marks.");
        return;
    }

    let total = math + science + english + computer + social + nepali;

    let percentage = total / 6;

    let grade;

    if(percentage >= 90){
        grade = "A+";
    }
    else if(percentage >= 80){
        grade = "A";
    }
    else if(percentage >= 70){
        grade = "B+";
    }
    else if(percentage >= 60){
        grade = "B";
    }
    else if(percentage >= 50){
        grade = "C";
    }
    else if(percentage >= 40){
        grade = "D";
    }
    else{
        grade = "Fail";
    }

    document.getElementById("result").innerHTML =
        `
        Total Marks: ${total}/600 <br>
        Percentage: ${percentage.toFixed(2)}% <br>
        Grade: ${grade}
        `;
}

</script>

</body>
</html>
